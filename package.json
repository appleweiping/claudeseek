  "type": "module",
  "license": "MIT",
  "author": "appleweiping",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/appleweiping/claudeseek.git"
  },
  "engines": {
    "node": ">=18.17"
  },
  "bin": {
    "claudeseek": "bin/claudeseek.js",
    "cseek": "bin/claudeseek.js"
  },
  "main": "src/index.js",
  "files": [
    "bin/",
    "src/",
    "public/",
    "prompts/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "node bin/claudeseek.js",
    "doctor": "node bin/claudeseek.js --doctor",
